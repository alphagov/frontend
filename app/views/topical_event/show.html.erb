<% content_for :head do %>
  <meta name="description" content="<%= content_item.description %>">

  <%= render "govuk_publishing_components/components/machine_readable_metadata",
    schema: :article,
    content_item: content_item.to_h %>
<% end %>

<% content_for :main_classes do %>govuk-!-padding-top-0<% end %>
<% content_for :body_classes do %>full-width__container<% end %>

<div class="full-width__element">
  <%= render "components/impact_header", {
    heading: content_item_presenter.page_title_options[:heading_text],
    description: content_item_presenter.page_title_options[:lead_paragraph],
    image: content_item_presenter.impact_image,
    image_type: content_item_presenter.impact_image&.type,
    variant: content_item_presenter.impact_variant,
  } %>
</div>
