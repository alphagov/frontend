<% text = capture do %>
  <% inverse = true if flexible_section.variant == "bridges" %>
  <%= render "govuk_publishing_components/components/heading", {
    text: flexible_section.title,
    font_size: "xl",
    margin_bottom: 6,
    heading_level: 1,
    inverse: inverse,
  } %>

  <%= render "govuk_publishing_components/components/lead_paragraph", {
    text: flexible_section.description,
    margin_bottom: 0,
    inverse: inverse,
  } %>
<% end %>

<div data-flexible-section="impact-header">
  <% if flexible_section.image %>
    <div class="impact-header <%= flexible_section.modifier_classes %>">
      <div class="impact-header__container">
        <div class="impact-header__detail">
          <%= text %>
        </div>

        <%= render "flexible_page/flexible_sections/shared/picture",
          image: flexible_section.image,
          style: "impact-header",
          alt_text: "" %>
      </div>
    </div>
  <% else %>
    <div class="impact-header impact-header--grid <%= flexible_section.modifier_classes %>">
      <div class="govuk-grid-row">
        <div class="govuk-grid-column-two-thirds">
          <%= text %>
        </div>
      </div>
    </div>
  <% end %>
</div>
