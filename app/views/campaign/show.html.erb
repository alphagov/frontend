    service_name: "Youth Justice Charter",
    service_name_url: "/campaign/show",
    hide_service_name_on_mobile: true,
    navigation_items: [
      {
        text: "Youth Justice Charter",
        href: "/campaign/show",
      },
      {
        text: "Stopped by the police",
        href: "#",
      },
      {
        text: "Going to court",
        href: "#",
      },
      {
        text: "Community Youth Justice Services",
        href: "#",
      },
      {
        text: "Going into youth custody",
        href: "#",
