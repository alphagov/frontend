<div class="govuk-grid-row gem-print-columns-none translation-nav-header">
  <div class="govuk-grid-column-two-thirds translation-nav-header__child">
    <%= render "govuk_publishing_components/components/heading", {
      text: options[:heading_text],
      context: options[:context],
      context_locale: options[:context_locale],
      dir: options[:page_text_direction],
      heading_level: 1,
      font_size: "xl",
      margin_bottom: 0,
    } %>
  </div>
  <% if options[:translations] %>
    <div class="govuk-grid-column-one-third translation-nav-header__child">
      <%= render "govuk_publishing_components/components/translation_nav", {
        translations: options[:translations],
        margin_bottom: 0,
      } %>
    </div>
  <% end %>
</div>
<% if options[:lead_paragraph] %>
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <%= render "govuk_publishing_components/components/lead_paragraph", {
        text: options[:lead_paragraph],
        dir: options[:page_text_direction],
      } %>
    </div>
  </div>
<% end %>
