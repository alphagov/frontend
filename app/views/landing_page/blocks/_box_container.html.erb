<%
  data_attributes = {
    module: "ga4-link-tracker",
    ga4_set_indexes: "",
    ga4_track_links_only: "",
    ga4_link: {
      event_name: "navigation",
      type: "box",
    }.to_json
  }
%>
<%= tag.div data: data_attributes do %>
  <% block.blocks.each do |child| %>
    <%= render "landing_page/blocks/#{child.type}", block: child %>
  <% end %>
<% end %>
