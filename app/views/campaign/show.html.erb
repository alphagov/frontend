<% end %>

<div class="full-width__container">
  <div class="full-width__element">
    <%= render "components/impact_header", {
      heading: "Youth Justice Charter",
      description: "Know your rights in the youth justice system",
      image: {
        sources: {
          desktop: "/assets/frontend/flexible-pages/youth_desktop_1x.jpg",
          desktop_2x: "/assets/frontend/flexible-pages/youth_desktop_2x.jpg",
          mobile: "/assets/frontend/flexible-pages/youth_mobile_1x.jpg",
          mobile_2x: "/assets/frontend/flexible-pages/youth_mobile_2x.jpg",
          tablet: "/assets/frontend/flexible-pages/youth_tablet_1x.jpg",
          tablet_2x: "/assets/frontend/flexible-pages/youth_tablet_2x.jpg",
        },
      },
    } %>
  </div>
</div>

<div class="govuk-grid-row">
  <div class="govuk-grid-column-two-thirds">
    <%= render "govuk_publishing_components/components/govspeak", { margin_bottom: 8 } do %>
      <h2>No matter who you are or what crime you've been accused of, all children have special rights.</h2>
      <p>This Youth Justice Charter explains <a href="#">what your rights are.</a>
      <p>It sets them out as standards, so you know what to expect at each stage of the <a href="https://example.com">youth justice system</a>.</p>
    <% end %>
  </div>
</div>

<div class="flexible-section" data-flexible-section="featured">
  <%= render "govuk_publishing_components/components/heading", {
    text: "Navigation",
    font_size: "l",
    padding: true,
    border_top: 5,
