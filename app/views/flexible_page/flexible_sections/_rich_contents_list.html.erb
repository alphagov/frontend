<nav class="<%= local_assigns[:container_class] || "" %>">
  <% if flexible_section.image %>
    <%= image_tag(flexible_section.image.src, alt: flexible_section.image.alt, class: "card__image govuk-!-width-full", loading: "lazy") %>
  <% end %>

  <%= render "govuk_publishing_components/components/contents_list", {
    contents: ContentsOutlinePresenter.new(flexible_section.contents_list).for_contents_list_component,
    id: "contents",
  } %>
</nav>
