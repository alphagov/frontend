<% content_for :head do %>
  <meta name="description" content="<%= content_item.description %>">
  <%= stylesheet_link_tag "views/_flexible-content", media: "all" %>

  <%= render "govuk_publishing_components/components/machine_readable_metadata",
    schema: :article,
    content_item: content_item.to_h %>
<% end %>

<% content_for :main_classes do %>govuk-!-padding-top-0<% end %>

<% content_for :before_content do %>
  <% content_item.flexible_sections.select { |fs| fs.before_content? }.each do |flexible_section| %>
    <%= render("flexible_page/flexible_sections/#{flexible_section.type}", flexible_section:) %>
  <% end %>
<% end %>

<% content_item.flexible_sections.reject { |fs| fs.before_content? }.each do |flexible_section| %>
  <%= render("flexible_page/flexible_sections/#{flexible_section.type}", flexible_section:) %>
<% end %>
